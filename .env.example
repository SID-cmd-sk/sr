# ========================================
# SR PLATFORM — Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# SUPABASE CONFIGURATION
# Get these from Supabase dashboard: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# GOOGLE APPS SCRIPT CONFIGURATION
# Create a new Google Apps Script project and deploy as web app
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
APPS_SCRIPT_SECRET_TOKEN=your-super-secret-token-change-this-in-production

# GOOGLE DRIVE CONFIGURATION
# Create folders in Google Drive and get their IDs
VITE_DRIVE_SR_FOLDER_ID=1ZhC-rDMoPRnKkK3OVDT3_eC_A5hBSahV
VITE_DRIVE_ACTIVITIES_FOLDER_ID=1ZhC-rDMoPRnKkK3OVDT3_eC_A5hBSahV
VITE_DRIVE_SPREADSHEET_ID=10k6weyGqYVEsUNf4DUe1fFGrBaB2sfOBIskhn2pFWGQ
VITE_DRIVE_SR_SHEET_NAME=SR Register
VITE_DRIVE_ACTIVITY_SHEET_NAME=Activity Log

# WHATSAPP BRIDGE CONFIGURATION
VITE_WA_BRIDGE_URL=http://localhost:3001
WA_PORT=3001
WA_AUTH_DIR=./wa_auth
WA_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# SMTP CONFIGURATION (Per-user, but defaults can be set here)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465

# SECURITY CONFIGURATION
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session security
SESSION_MAX_AGE_HOURS=24
SESSION_REFRESH_THRESHOLD_HOURS=1

# Feature flags
FEATURE_EMAIL_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_GOOGLE_DRIVE_ENABLED=true
FEATURE_MFA_ENABLED=false

# Logging
LOG_LEVEL=info
DEBUG_MODE=false
