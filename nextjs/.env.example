# ============================================================
# SR PLATFORM — Environment Variables
# Copy this file to .env.local (Next.js) and fill in values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# From: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── App URL ────────────────────────────────────────────────────
# Used for generating email links and auth callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Email / SMTP ───────────────────────────────────────────────
# SMTP settings stored in DB (Admin → Settings → Email)
# Password stored here ONLY for security
SMTP_PASSWORD=your_smtp_password_here

# ── WhatsApp Bridge ────────────────────────────────────────────
# URL of the running wa-service/bridge.js
WA_BRIDGE_URL=http://localhost:3001
# On VPS with internal networking: WA_BRIDGE_URL=http://127.0.0.1:3001

# ── Google Apps Script ─────────────────────────────────────────
# Also stored in DB settings (Admin → Settings → Drive)
# Optionally override here for server-side calls
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
APPS_SCRIPT_TOKEN=your_secret_token_matching_Code.gs

# ── Node ───────────────────────────────────────────────────────
NODE_ENV=development
